# Скопируйте в .env в корне репозитория и подставьте значения.
# Docker Compose подхватывает переменные автоматически.

# Пароль PostgreSQL (в docker-compose для сервиса db и backend)
DB_PASSWORD=postgres

# Публичный URL фронтенда (редиректы после активации аккаунта по почте)
APP_FRONTEND_URL=http://localhost

# CORS: через запятую, без пробелов или с пробелами — как в Spring
APP_CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1

# SMTP (пусть лучше задаётся явно в проде)
# MAIL_PASSWORD=

# Включить отладочные эндпоинты /api/dev/* (SMTP-тест и т.д.)
# DEV_TOOLS_ENABLED=false

# --- Гибридное хранилище (MinIO в docker-compose) ---
# APP_STORAGE_OBJECT_ENABLED=true
# APP_STORAGE_OBJECT_ENDPOINT=http://minio:9000
# APP_STORAGE_NEW_FILES=object
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
